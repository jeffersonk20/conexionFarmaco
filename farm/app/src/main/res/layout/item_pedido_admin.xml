<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@color/white">

        <TextView
            android:id="@+id/tvPedidoCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cliente"
            android:textColor="@color/azul_primario"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvPedidoFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="2024-01-01"
            android:textColor="@color/texto_secundario"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvPedidoEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pendiente"
            android:textColor="@color/azul_vibrante"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#EBF5FB"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp" />

        <TextView
            android:id="@+id/tvPedidoTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Total: $0.00"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPedidoDetalleItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Detalle de productos..."
            android:textColor="@color/texto_secundario"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btnGenerarFactura"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_marginTop="8dp"
            android:text="Generar Factura"
            android:textSize="12sp"
            android:backgroundTint="@color/azul_primario"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:padding="0dp"
            android:gravity="center" />

    </LinearLayout>
</androidx.cardview.widget.CardView>