<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_soft">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/azul_primario"
        android:paddingHorizontal="16dp"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/btnFactAtras"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white"
            android:contentDescription="Atrás" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Facturación"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección de Envío"
                android:textColor="@color/azul_primario"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@color/white">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nombre del Receptor" android:textColor="@color/azul_vibrante" android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etFactNombre"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/modern_edittext"
                        android:hint="Ej. Ramael Córdova"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"
                        android:textSize="16sp"
                        android:inputType="textPersonName"
                        android:paddingStart="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dirección Completa" android:textColor="@color/azul_vibrante" android:textStyle="bold" android:layout_marginTop="12dp" />
                    <EditText
                        android:id="@+id/etFactDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:background="@drawable/modern_edittext"
                        android:hint="Calle, Barrio, Ciudad, Departamento"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:padding="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Teléfono de contacto" android:textColor="@color/azul_vibrante" android:textStyle="bold" android:layout_marginTop="12dp" />
                    <EditText
                        android:id="@+id/etFactTel"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/modern_edittext"
                        android:hint="7777-7777"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"
                        android:inputType="phone"
                        android:paddingStart="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <CheckBox
                android:id="@+id/cbPredeterminado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usar como dirección predeterminada"
                android:textColor="@color/texto_secundario"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnFactContinuar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="CONTINUAR"
                android:backgroundTint="@color/azul_vibrante"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
